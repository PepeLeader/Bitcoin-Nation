{
    "name": "bitcoin-nation-tests",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "npx tsx BitcoinNationNFT.test.ts && npx tsx BitcoinNationFactory.test.ts",
