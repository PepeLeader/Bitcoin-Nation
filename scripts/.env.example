# Option A: Mnemonic (provides both ECDSA + ML-DSA keys for deployment)
MNEMONIC="your twenty four word seed phrase goes here replace with real mnemonic words for deployment"

# Option B: WIF private key (ECDSA only — ML-DSA will be null, may fail if node requires it)
# WIF_KEY=cNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Network: regtest or mainnet
NETWORK=regtest
